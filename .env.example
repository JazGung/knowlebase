# ============================================================
# 知识库系统环境变量配置
# 复制此文件为 .env 并修改相应配置
# cp .env.example .env
# ============================================================

# ====================
# 数据卷根目录配置
# 团队成员可自定义此变量，使数据持久化到本地目录
# Windows 示例: ../knowlebase-volume 或 D:/docker-volumes/knowlebase
# Mac/Linux 示例: ~/docker-volumes/knowlebase
# ====================
VOLUME_BASE=../knowlebase-volume

# ====================
# 数据库连接配置
# ====================

# PostgreSQL 配置
POSTGRES_USER=knowlebase
POSTGRES_PASSWORD=knowlebase_password
POSTGRES_DB=knowlebase
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ElasticSearch 配置
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Milvus 向量数据库配置
MILVUS_HOST=milvus
MILVUS_PORT=19530

# Neo4j 图数据库配置
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowlebase_password

# ====================
# 应用程序配置
# ====================

# FastAPI 后端配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# 向量嵌入模型配置
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
EMBEDDING_DEVICE=cpu

# 文档处理配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_FILE_SIZE=104857600

# 搜索配置
SEARCH_KEYWORD_WEIGHT=0.4
SEARCH_SEMANTIC_WEIGHT=0.4
SEARCH_GRAPH_WEIGHT=0.2
SEARCH_RESULTS_LIMIT=20

# ====================
# 安全配置
# ====================

JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=["http://localhost:5173", "http://localhost:8000"]
